<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Base theme inherits from Theme.SplashScreen.
        This is what makes the OS splash screen work correctly.
        postSplashScreenTheme = the theme applied AFTER the splash dismisses.
        windowSplashScreenBackground = colour shown behind the icon.
        windowSplashScreenAnimatedIcon = the animated/static icon in the centre.
    -->
    <style name="Theme.AiAutoCaptioner" parent="Theme.SplashScreen">
        <!-- Splash screen background colour — use your brand colour -->
        <item name="windowSplashScreenBackground">@color/splash_background</item>

        <item name="windowSplashScreenAnimatedIcon">@drawable/untitled</item>
        <!-- After splash dismisses, apply Material3 dynamic colour theme -->
        <item name="postSplashScreenTheme">@style/Theme.AiAutoCaptioner.App</item>
    </style>
    <style name="Theme.AiAutoCaptioner.App" parent="android:Theme.Material.Light.NoActionBar" />

</resources>